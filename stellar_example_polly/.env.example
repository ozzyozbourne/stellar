# =============================================================================
# POLLYBOT APP - ENVIRONMENT CONFIGURATION EXAMPLE
# =============================================================================
# Copy this file to .env and fill in the actual values
# DO NOT commit your .env file to version control!

# =============================================================================
# DATABASE
# =============================================================================
# Runtime connection. On Supabase, use the TRANSACTION POOLER string (port 6543).
DATABASE_URL="postgresql://user:password@localhost:5432/pollybot_db"
# CLI/migrations connection (prisma db push / studio). On Supabase, use the
# DIRECT connection string (port 5432). Optional for local/non-pooled Postgres.
# DIRECT_URL="postgresql://postgres:password@db.<project-ref>.supabase.co:5432/postgres"

# =============================================================================
# NEXTAUTH.JS CONFIGURATION
# =============================================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-generate-with-openssl-rand-hex-32"

# =============================================================================
# WIDGET API CONFIGURATION
# =============================================================================
NEXT_PUBLIC_WIDGET_API_URL="http://localhost:3000"

# =============================================================================
# OAUTH PROVIDERS
# =============================================================================

# Google OAuth (for authentication & Google Drive API)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Discord OAuth (for authentication)
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"

# GitHub OAuth
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# =============================================================================
# NOTION INTEGRATION
# =============================================================================
NOTION_CLIENT_ID="your-notion-client-id"
NOTION_CLIENT_SECRET="your-notion-client-secret"
NOTION_REDIRECT_URI="http://localhost:3000/api/integrations/notion/callback"
NOTION_API_VERSION="2025-09-03"
NOTION_ENCRYPTION_KEY="your-notion-encryption-key-generate-with-openssl-rand-hex-32"

# =============================================================================
# AI PROVIDERS
# =============================================================================
OPENAI_API_KEY="sk-your-openai-api-key"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"
GOOGLE_AI_API_KEY="your-google-ai-api-key"

# =============================================================================
# OBSERVABILITY (LANGSMITH) — disabled by default, zero overhead when off
# =============================================================================

LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="pollybot"
# Trace link template shown to super admins in admin-manager conversations view.
# Use {runId} as the placeholder. If your LangSmith workspace is private, set
# this to e.g. https://smith.langchain.com/o/<org-slug>/r/{runId}
NEXT_PUBLIC_LANGSMITH_TRACE_URL_TEMPLATE="https://smith.langchain.com/runs/{runId}"

# =============================================================================
# VECTOR DATABASE (PINECONE)
# =============================================================================
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_INDEX_NAME="bge-m3"

# =============================================================================
# EMBEDDINGS (HuggingFace BGE-M3 endpoint)
# =============================================================================
HF_EMBEDDING_URL="https://your-embedding-endpoint.endpoints.huggingface.cloud"
HF_EMBEDDING_TOKEN="hf_your-token"
# Set to true if your HF embedding endpoint supports sparse vectors (bge-m3 custom handler)
# HF_EMBEDDING_SPARSE=true

# =============================================================================
# RERANKER (Neural Re-ranking for Search Quality)
# =============================================================================
# Provider: huggingface (production) | cohere (local dev, free tier) | none (disabled)
RERANKER_PROVIDER="none"
# HuggingFace config (production) — SEPARATE endpoint from embedding endpoint
# HF_RERANKER_URL="https://your-reranker-endpoint.endpoints.huggingface.cloud"
# HF_RERANKER_TOKEN="hf_your-token"           # can be same token as embedding
# RERANKER_MODEL="bge-reranker-v2-m3"         # for logging
# Cohere config (local dev) — get free API key at dashboard.cohere.com
# COHERE_API_KEY=""
# RERANKER_MODEL="rerank-v3.5"
# Tuning
RERANKER_TOP_K="10"                           # return top N after reranking
RETRIEVAL_TOP_K="30"                          # fetch top N from Pinecone before reranking

# =============================================================================
# DISCORD BOT CONFIGURATION
# =============================================================================

# For User Authentication (Discord OAuth login)
# Uses: DISCORD_CLIENT_ID and DISCORD_CLIENT_SECRET from OAuth PROVIDERS section

# For Custom Bot Integration (user's own bot OAuth flow)
# Also uses: DISCORD_CLIENT_ID and DISCORD_CLIENT_SECRET
NEXT_PUBLIC_DISCORD_CLIENT_ID="your-discord-client-id"

# For PollyBot Managed Bot (separate Discord app with bot permissions)
POLLYBOT_DISCORD_CLIENT_ID="your-pollybot-discord-client-id"
POLLYBOT_DISCORD_CLIENT_SECRET="your-pollybot-discord-client-secret"
POLLYBOT_DISCORD_BOT_TOKEN="your-pollybot-discord-bot-token"
NEXT_PUBLIC_POLLYBOT_DISCORD_CLIENT_ID="your-pollybot-discord-client-id"

# =============================================================================
# PUSHER / SOKETI (REAL-TIME)
# Single source of truth. SOKETI_* and *_SCHEME variants are no longer read.
# =============================================================================

# Server-side Pusher/Soketi credentials
PUSHER_APP_ID="your-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_HOST="localhost"
PUSHER_PORT="6001"
PUSHER_USE_TLS="false"
PUSHER_CLUSTER="mt1"

# Client-side (browser) - must be present at build time
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_HOST="localhost"
NEXT_PUBLIC_PUSHER_PORT="6001"
NEXT_PUBLIC_PUSHER_USE_TLS="false"
NEXT_PUBLIC_PUSHER_CLUSTER="mt1"

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
EMAIL_FROM="PollyBot <admin@yourdomain.com>"
RESEND_API_KEY="re_your-resend-api-key"

# =============================================================================
# BRANDING CONFIGURATION
# =============================================================================
NEXT_PUBLIC_BRAND_NAME="polly"
NEXT_PUBLIC_BRAND_DISPLAY_NAME="PollyBot"
NEXT_PUBLIC_LOGO_LIGHT="/images/pollybot-logo-light.png"
NEXT_PUBLIC_LOGO_DARK="/images/pollybot-logo-dark.png"
NEXT_PUBLIC_LOGO_ALT="PollyBot Logo"

# =============================================================================
# WORKER / VPS CONFIGURATION
# =============================================================================
NEXT_PUBLIC_VPS_URL="http://localhost:3001"
VPS_API_KEY="your-vps-api-key"
WORKER_BASE_URL="http://localhost:3001"

# =============================================================================
# CLOUDFLARE R2 (FILE STORAGE)
# =============================================================================
CLOUDFLARE_R2_ACCOUNT_ID="your-cloudflare-account-id"
CLOUDFLARE_R2_ACCESS_KEY_ID="your-r2-access-key-id"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
CLOUDFLARE_R2_BUCKET_NAME="your-r2-bucket-name"
CLOUDFLARE_R2_PUBLIC_URL="https://media.yourdomain.com"  # Custom domain recommended over r2.dev

# =============================================================================
# REDIS (RATE LIMITING)
# =============================================================================
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
WIDGET_RATE_LIMIT="50"
WIDGET_RATE_WINDOW="hour"

# =============================================================================
# RENDER DEPLOYMENT (OPTIONAL)
# =============================================================================
RENDER_API_KEY="rnd_your-render-api-key"
RENDER_SERVICE_ID="srv-your-render-service-id"

# =============================================================================
# SPERSE CRM CONFIGURATION
# =============================================================================
SPERSE_API_KEY="your-sperse-api-key"
SPERSE_API_BASE_URL="https://your-sperse-instance.com"
SPERSE_TENANT_ID="your-tenant-id"

# =============================================================================
# MULTI-TENANT CONFIGURATION
# =============================================================================
# Comma-separated list of emails to assign as platform super admins
# These users will have full platform access across all tenants
SUPER_ADMIN_EMAILS="admin@yourdomain.com"

# =============================================================================
# INNGEST (DURABLE WORKFLOW EXECUTION)
# =============================================================================
# LOCAL DEV: leave INNGEST_DEV=1 and run the Inngest Dev Server in a 2nd terminal:
#   npx inngest-cli@latest dev        (dashboard at http://localhost:8288)
# The SDK auto-connects to localhost:8288 when no signing key is set.
INNGEST_DEV=1

# STAGING / PRODUCTION: set these and set INNGEST_DEV=0. With Inngest Cloud,
# leave INNGEST_BASE_URL unset. With a self-hosted instance, point
# INNGEST_BASE_URL at it.
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
# INNGEST_BASE_URL=

# Async chat routing. When '1', workflows that contain a delay/approval/handoff
# node are dispatched to Inngest and the user gets an interim ack; the real
# reply arrives over Soketi.
WORKFLOW_ASYNC_ENABLED=1

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV="development"
